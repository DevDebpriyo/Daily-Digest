{
  "name": "daily-gmail-digest",
  "version": "1.0.0",
  "description": "A lightweight, fully autonomous automation service that fetches unread emails from multiple Gmail accounts, filters noise, and delivers a clean daily digest via Telegram and Discord.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts"
  },
  "keywords": [
    "gmail",
    "digest",
    "telegram",
    "discord",
    "automation",
    "email"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^146.0.0",
    "mongoose": "^9.6.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
